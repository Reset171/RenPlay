<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/bottom_sheet_title"
        style="@style/OneUI.BottomSheetDialogTitleStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp" />

    <dev.oneuiproject.oneui.widget.RoundedNestedScrollView
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginHorizontal="24dp"
        android:background="?attr/roundedCornerColor"
        app:roundedCorners="all">

        <TextView
            android:id="@+id/bottom_sheet_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:fontFamily="monospace"
            android:textIsSelectable="true" />

    </dev.oneuiproject.oneui.widget.RoundedNestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <Button
            android:id="@+id/btn_action"
            style="@style/OneUI.ContainedPrimaryColorButtonTheme"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
